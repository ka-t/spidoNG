//
// {{ r.path }} [{{ r.methods | join(', ') }}] → table={{ r.table }} pk={{ r.primary_key }}
//   filters: {{ r.filters.keys() | list | length }} configured
//   sort:    {{ r.sort_options | length }} fields
//   relations: {{ r.relations.keys() | list | length }} (auto-embedded into list/get)
//   ownership: {{ 'on' if r.ownership else 'off' }}
//   soft_delete: {{ r.soft_delete or 'off' }}

#include "{{ r.table }}.h"
#include "../service_helpers.h"

{# Roles source: when JWT is on, pull the roles claim from the payload
   (spido already verified signature/exp/etc before we get here). Strip
   JSON-array brackets if the claim was emitted as ["admin","user"]. #}
{% macro role_check(perms, header) -%}
{% if perms and perms.roles %}
        {
{% if auth.type == 'jwt' %}
            auto _roles_csv = jwt_claim(jwt_payload(req), "{{ auth.roles_claim }}");
            if (!_roles_csv.empty() && _roles_csv.front() == '[') {
                _roles_csv = _roles_csv.substr(1, _roles_csv.size() - 2);
                std::string _clean; _clean.reserve(_roles_csv.size());
                for (char c : _roles_csv) if (c != '"' && c != ' ') _clean += c;
                _roles_csv = std::move(_clean);
            }
{% else %}
            std::string _roles_csv(req.header("{{ header }}"));
{% endif %}
            if (!any_role_matches(_roles_csv, {
{% for role in perms.roles %}
                "{{ role }}"{% if not loop.last %},{% endif %}
{% endfor %}
            })) { res.set_status(403).text("forbidden"); return; }
        }
{% endif %}
{%- endmacro %}

{% macro bypass_own(perms, header) -%}
{% if perms and perms.bypass_ownership %}
        bool _bypass_own = false;
        {
{% if auth.type == 'jwt' %}
            auto _roles_csv = jwt_claim(jwt_payload(req), "{{ auth.roles_claim }}");
            if (!_roles_csv.empty() && _roles_csv.front() == '[') {
                _roles_csv = _roles_csv.substr(1, _roles_csv.size() - 2);
                std::string _clean; _clean.reserve(_roles_csv.size());
                for (char c : _roles_csv) if (c != '"' && c != ' ') _clean += c;
                _roles_csv = std::move(_clean);
            }
{% else %}
            std::string _roles_csv(req.header("{{ header }}"));
{% endif %}
            _bypass_own = any_role_matches(_roles_csv, {
{% for role in perms.bypass_ownership %}
                "{{ role }}"{% if not loop.last %},{% endif %}
{% endfor %}
            });
        }
{% else %}
        constexpr bool _bypass_own = false;
{% endif %}
{%- endmacro %}

{# Read the caller's user id. JWT mode pulls from the configured claim
   in the verified token payload; header mode falls back to a trusted
   reverse-proxy header. Both return std::string. #}
{% macro user_id_expr(ownership) -%}
{% if auth.type == 'jwt' %}
jwt_claim(jwt_payload(req), "{{ auth.user_claim }}")
{% else %}
std::string(req.header("{{ ownership.header }}"))
{% endif %}
{%- endmacro %}

#include <array>
#include <atomic>
#include <chrono>
#include <span>
#include <string>
#include <string_view>
#include <utility>
#include <vector>

namespace svc::handlers {

namespace {

// Column order used by the body parser; matches INSERT/SELECT layout.
constexpr std::array<std::string_view, {{ r.columns | length }}>
    cols_{{ r.table }} = { {% for col in r.columns %}"{{ col }}"{% if not loop.last %}, {% endif %}{% endfor %} };

constexpr spido_pg::EndpointId kEp_{{ r.table }} = {{ r.endpoint_id }};

{% if r.field_masking %}
// Build the SELECT projection for {{ r.table }} requests. With no
// ?fields= param, defaults to every column. With ?fields=a,b each comma-
// separated name is whitelisted against the resource's columns — unknown
// names cause the caller to return an empty string (handler then 400s).
// Relation aggregations are appended by the caller, not here, so they
// always come through.
std::string project_{{ r.table }}(std::string_view fields_q) {
    if (fields_q.empty()) return "{{ r.select_list_base }}";
    std::string out;
    bool first = true;
    while (!fields_q.empty()) {
        auto _comma = fields_q.find(',');
        auto _f = fields_q.substr(0, _comma);
        std::string_view _qc;
{% for col in r.columns %}
        if (_f == "{{ col }}") _qc = "{{ r.table }}.{{ col }}";
{% endfor %}
        if (_qc.empty()) return {};   // unknown field
        if (!first) out += ", ";
        out += _qc;
        first = false;
        if (_comma == std::string_view::npos) break;
        fields_q.remove_prefix(_comma + 1);
    }
    return first ? std::string{} : out;
}
{% endif %}

{% if r.agg_count_enabled or r.agg_stats_enabled %}
// Apply the resource's ownership + soft_delete + request-driven filter
// WHERE clauses to `sql` and the corresponding params. Returns false
// (after populating `res`) if the request was rejected (missing auth).
// Used by the aggregation endpoints below; the GET list handler builds
// the same clauses inline (refactoring later).
bool apply_where_{{ r.table }}(spido::Request& req, spido::Response& res,
                               std::string& sql,
                               std::vector<spido_pg::PgParam>& params,
                               bool bypass_ownership) {
    bool any_where = false;
    auto add_where = [&](std::string_view clause) {
        sql.append(any_where ? " AND " : " WHERE ");
        sql.append(clause);
        any_where = true;
    };
    (void)add_where;
    (void)bypass_ownership;
{% if r.ownership %}
    if (!bypass_ownership) {
        std::string owner_id = {{ user_id_expr(r.ownership) }};
        if (owner_id.empty()) { res.set_status(401).text("auth required"); return false; }
        {
            std::string clause; clause.reserve(48);
            clause.append("{{ r.ownership_sql_col }} = $");
            clause.append(std::to_string(params.size() + 1));
            add_where(clause);
            params.push_back(spido_pg::PgParam::from_text(owner_id));
        }
    }
{% endif %}
{% if r.soft_delete %}
    add_where("{{ r.soft_delete_sql_col }} IS NULL");
{% endif %}
{% for f in r.filter_list %}
{% if f.takes_param %}
    if (auto qv = qparam(req.query, "{{ f.param }}"); !qv.empty()) {
        std::string idx_str = std::to_string(params.size() + 1);
{% if f.wrap == "contains" %}
        std::string val = "%"; val.append(spido::Request::decode(qv, true)); val.push_back('%');
{% elif f.wrap == "starts_with" %}
        std::string val = spido::Request::decode(qv, true); val.push_back('%');
{% elif f.wrap == "ends_with" %}
        std::string val = "%"; val.append(spido::Request::decode(qv, true));
{% elif f.wrap == "in_array" %}
        std::string val = csv_to_pg_array(spido::Request::decode(qv, true));
{% else %}
        std::string val = spido::Request::decode(qv, true);
{% endif %}
{% if f.wrap == "in_array" %}
        std::string clause;
        clause.append("{{ f.column }} {{ f.sql_op }}($").append(idx_str).append("::text[])");
{% else %}
        std::string clause;
        clause.append("{{ f.column }} {{ f.sql_op }} $").append(idx_str);
{% endif %}
        add_where(clause);
        params.push_back(spido_pg::PgParam::from_text(val));
    }
{% else %}
    if (qparam_has(req.query, "{{ f.param }}")) {
        add_where("{{ f.column }} {{ f.sql_op }}");
    }
{% endif %}
{% endfor %}
    return true;
}
{% endif %}

{% if r.has_validations %}
// Field-level validation. is_create=true for POST (enforce required),
// false for PUT (partial update — required fields can be absent).
spido::Json::Array validate_{{ r.table }}(const spido_pg::JsonBody& body, bool is_create) {
    spido::Json::Array errs;
{% for v in r.validation_rules %}
    {
        auto _raw = body.get("{{ v.column }}");
        bool _is_null = body.is_null("{{ v.column }}");
{% if v.required %}
        if (is_create && !_raw && !_is_null) {
            push_field_error(errs, "{{ v.column }}", "required");
        }
{% else %}
        (void)is_create;
{% endif %}
        if (_raw && !_is_null) {
            std::string_view _s = *_raw;
{% if v.type == "int" or v.type == "bigint" %}
            long long _n;
            if (!parse_int_strict(_s, _n)) {
                push_field_error(errs, "{{ v.column }}", "must be an integer");
            }
{% if v.min is not none %}
            else if (_n < {{ v.min }}LL) {
                push_field_error(errs, "{{ v.column }}", "below minimum ({{ v.min }})");
            }
{% endif %}
{% if v.max is not none %}
            else if (_n > {{ v.max }}LL) {
                push_field_error(errs, "{{ v.column }}", "above maximum ({{ v.max }})");
            }
{% endif %}
{% elif v.type == "float" %}
            double _d;
            if (!parse_double_strict(_s, _d)) {
                push_field_error(errs, "{{ v.column }}", "must be a number");
            }
{% if v.min is not none %}
            else if (_d < {{ v.min }}) {
                push_field_error(errs, "{{ v.column }}", "below minimum ({{ v.min }})");
            }
{% endif %}
{% if v.max is not none %}
            else if (_d > {{ v.max }}) {
                push_field_error(errs, "{{ v.column }}", "above maximum ({{ v.max }})");
            }
{% endif %}
{% elif v.type == "bool" %}
            if (_s != "true" && _s != "false") {
                push_field_error(errs, "{{ v.column }}", "must be true or false");
            }
{% elif v.type == "email" %}
            if (!looks_like_email(_s)) {
                push_field_error(errs, "{{ v.column }}", "invalid email");
            }
{% elif v.type == "uuid" %}
            if (!looks_like_uuid(_s)) {
                push_field_error(errs, "{{ v.column }}", "invalid uuid");
            }
{% else %}
{% if v.min_length is not none %}
            if (_s.size() < {{ v.min_length }}) {
                push_field_error(errs, "{{ v.column }}", "too short (min {{ v.min_length }})");
            }
{% endif %}
{% if v.max_length is not none %}
            if (_s.size() > {{ v.max_length }}) {
                push_field_error(errs, "{{ v.column }}", "too long (max {{ v.max_length }})");
            }
{% endif %}
{% if v.enum %}
            if (
{% for e in v.enum %}
                _s != "{{ e }}"{% if not loop.last %} &&{% endif %}
{% endfor %}
            ) {
                push_field_error(errs, "{{ v.column }}", "not in allowed values");
            }
{% endif %}
{% endif %}
        }
    }
{% endfor %}
    return errs;
}
{% endif %}

} // namespace

void register_{{ r.table }}_routes(spido::Server& srv, spido_pg::Db& db) {
{% if r.agg_count_enabled %}
    // GET {{ r.path }}/count → row count under the same filters as list.
    // Bypasses any relation joins — COUNT is over the main table only.
    srv.get("{{ r.path }}/count", [&db](spido::Request& req, spido::Response& res) {
        auto t0 = std::chrono::steady_clock::now();
        auto& rs = db.endpoints().state(kEp_{{ r.table }});
        {{ role_check(r.perms_count, r.perms_header) }}
        {{ bypass_own(r.perms_count, r.perms_header) }}
        std::string sql = "SELECT COUNT(*) FROM {{ r.table }}";
        std::vector<spido_pg::PgParam> params;
        if (!apply_where_{{ r.table }}(req, res, sql, params, _bypass_own)) return;

        auto pgres = db.query_cached(
            sql, std::span<const spido_pg::PgParam>(params),
            std::chrono::seconds({{ r.cache_ttl_s }}), "{{ r.table }}");
        auto dt_us = std::chrono::duration_cast<std::chrono::microseconds>(
                       std::chrono::steady_clock::now() - t0).count();
        rs.record_read(static_cast<uint64_t>(dt_us));
        if (!pgres.ok()) { send_db_error(res, pgres); return; }
        long long _count = 0;
        if (!pgres.rows.empty()) {
            if (auto v = pgres.i8(0, 0)) _count = *v;
        }
        spido::Json::Object _o;
        _o.emplace_back("count", spido::Json((long long)_count));
        res.json(spido::Json(std::move(_o)));
    }{% if r.needs_auth %}, /*require_auth=*/true{% endif %});
{% endif %}
{% if r.agg_stats_enabled %}
    // GET {{ r.path }}/stats → aggregations over each configured column.
    // Response: {col: {op: value, ...}, ...}
    srv.get("{{ r.path }}/stats", [&db](spido::Request& req, spido::Response& res) {
        auto t0 = std::chrono::steady_clock::now();
        auto& rs = db.endpoints().state(kEp_{{ r.table }});
        {{ role_check(r.perms_stats, r.perms_header) }}
        {{ bypass_own(r.perms_stats, r.perms_header) }}
        std::string sql = "SELECT {{ r.agg_stats_sql_select }} FROM {{ r.table }}";
        std::vector<spido_pg::PgParam> params;
        if (!apply_where_{{ r.table }}(req, res, sql, params, _bypass_own)) return;

        auto pgres = db.query_cached(
            sql, std::span<const spido_pg::PgParam>(params),
            std::chrono::seconds({{ r.cache_ttl_s }}), "{{ r.table }}");
        auto dt_us = std::chrono::duration_cast<std::chrono::microseconds>(
                       std::chrono::steady_clock::now() - t0).count();
        rs.record_read(static_cast<uint64_t>(dt_us));
        if (!pgres.ok()) { send_db_error(res, pgres); return; }
        spido::Json::Object _out;
        size_t _idx = 0;
{% for col in r.agg_stats_columns %}
        {
            spido::Json::Object _col_obj;
{% for op in r.agg_stats_ops %}
            _col_obj.emplace_back("{{ op }}", extract_value(pgres, 0, _idx));
            ++_idx;
{% endfor %}
            _out.emplace_back("{{ col }}", spido::Json(std::move(_col_obj)));
        }
{% endfor %}
        res.json(spido::Json(std::move(_out)));
    }{% if r.needs_auth %}, /*require_auth=*/true{% endif %});
{% endif %}

{% if 'GET' in r.methods %}
    // GET {{ r.path }} → list query (filters/sort/pagination/relations driven by config)
    srv.get("{{ r.path }}", [&db](spido::Request& req, spido::Response& res) {
        auto t0 = std::chrono::steady_clock::now();
        auto& rs = db.endpoints().state(kEp_{{ r.table }});
        {{ role_check(r.perms_list, r.perms_header) }}
        {{ bypass_own(r.perms_list, r.perms_header) }}
        std::string sql; sql.reserve(256);
        sql += "SELECT ";
{% if r.field_masking %}
        {
            std::string _proj = project_{{ r.table }}(qparam(req.query, "fields"));
            if (_proj.empty()) { res.set_status(400).text("invalid fields"); return; }
            sql += _proj;
        }
{% else %}
        sql += "{{ r.select_list_base }}";
{% endif %}
{% if r.relation_aggs %}
        sql += ", {{ r.relation_aggs }}";
{% endif %}
{% if r.pagination.include_total %}
        // include_total: window function gives us the post-WHERE row count
        // in every row. We strip this column before emitting the response.
        sql += ", COUNT(*) OVER () AS _spido_total";
{% endif %}
        sql += " FROM {{ r.from_clause }}";
        std::vector<spido_pg::PgParam> params;
        bool any_where = false;
        auto add_where = [&](std::string_view clause) {
            sql.append(any_where ? " AND " : " WHERE ");
            sql.append(clause);
            any_where = true;
        };
        (void)add_where;

{% if r.ownership %}
        if (!_bypass_own) {
            // ownership: only rows belonging to the caller
            std::string owner_id = {{ user_id_expr(r.ownership) }};
            if (owner_id.empty()) { res.set_status(401).text("auth required"); return; }
            std::string clause; clause.reserve(48);
            clause.append("{{ r.ownership_sql_col }} = $");
            clause.append(std::to_string(params.size() + 1));
            add_where(clause);
            params.push_back(spido_pg::PgParam::from_text(owner_id));
        }
{% endif %}
{% if r.soft_delete %}
        add_where("{{ r.soft_delete_sql_col }} IS NULL");
{% endif %}
{% for f in r.filter_list %}
        // filter: {{ f.param }} → {{ f.column }} {{ f.sql_op }}
{% if f.takes_param %}
        if (auto qv = qparam(req.query, "{{ f.param }}"); !qv.empty()) {
            std::string idx_str = std::to_string(params.size() + 1);
{% if f.wrap == "contains" %}
            std::string val = "%"; val.append(spido::Request::decode(qv, true)); val.push_back('%');
{% elif f.wrap == "starts_with" %}
            std::string val = spido::Request::decode(qv, true); val.push_back('%');
{% elif f.wrap == "ends_with" %}
            std::string val = "%"; val.append(spido::Request::decode(qv, true));
{% elif f.wrap == "in_array" %}
            std::string val = csv_to_pg_array(spido::Request::decode(qv, true));
{% else %}
            std::string val = spido::Request::decode(qv, true);
{% endif %}
{% if f.wrap == "in_array" %}
            std::string clause;
            clause.append("{{ f.column }} {{ f.sql_op }}($").append(idx_str).append("::text[])");
{% else %}
            std::string clause;
            clause.append("{{ f.column }} {{ f.sql_op }} $").append(idx_str);
{% endif %}
            add_where(clause);
            params.push_back(spido_pg::PgParam::from_text(val));
        }
{% else %}
        if (qparam_has(req.query, "{{ f.param }}")) {
            add_where("{{ f.column }} {{ f.sql_op }}");
        }
{% endif %}
{% endfor %}

{% if r.pagination.mode == 'cursor' %}
        // cursor pagination: filter rows past the last-seen pk. The
        // cursor is opaque to the client — just the pk value of the
        // final row from the previous page.
        if (auto _cv = qparam(req.query, "cursor"); !_cv.empty()) {
            std::string _cs = spido::Request::decode(_cv, true);
            std::string _clause;
            _clause.append("{{ r.table }}.{{ r.primary_key }} > $")
                   .append(std::to_string(params.size() + 1));
            add_where(_clause);
            params.push_back(spido_pg::PgParam::from_text(_cs));
        }
{% endif %}
{% if r.group_by_clause %}
        sql.append(" {{ r.group_by_clause }}");
{% endif %}

        // sort
{% if r.pagination.mode == 'cursor' %}
        // cursor mode forces ORDER BY pk ASC so the cursor advances
        // monotonically. User sort param is ignored.
        sql.append(" ORDER BY {{ r.table }}.{{ r.primary_key }} ASC");
{% elif r.sort_options %}
        {
            auto sv = qparam(req.query, "sort");
            if (sv.empty()) {
{% if r.sort_default_sql %}
                sql.append(" ORDER BY {{ r.sort_default_sql }}");
{% endif %}
            } else {
                bool desc = false;
                if (!sv.empty() && sv[0] == '-') { desc = true; sv.remove_prefix(1); }
                std::string_view sqlcol;
{% for so in r.sort_options %}
                if (sv == "{{ so.param }}") sqlcol = "{{ so.sql_col }}";
{% endfor %}
                if (sqlcol.empty()) { res.set_status(400).text("invalid sort field"); return; }
                sql.append(" ORDER BY ").append(sqlcol).append(desc ? " DESC" : " ASC");
            }
        }
{% elif r.sort_default_sql %}
        sql.append(" ORDER BY {{ r.sort_default_sql }}");
{% endif %}

        // pagination
{% if r.pagination.mode == 'cursor' %}
        int _page_size = {{ r.pagination.default }};
        if (auto _v = qparam(req.query, "page_size"); !_v.empty()) {
            int _n = 0;
            for (char c : _v) { if (c < '0' || c > '9') { _n = 0; break; } _n = _n*10 + (c - '0'); }
            if (_n > 0) _page_size = (_n > {{ r.pagination.max }}) ? {{ r.pagination.max }} : _n;
        }
        sql.append(" LIMIT $").append(std::to_string(params.size() + 1));
        params.push_back(spido_pg::PgParam::from_text(std::to_string(_page_size)));
{% else %}
        auto pg = parse_pagination(req.query, {{ r.pagination.default }}, {{ r.pagination.max }});
        sql.append(" LIMIT $").append(std::to_string(params.size() + 1));
        params.push_back(spido_pg::PgParam::from_text(std::to_string(pg.size)));
        sql.append(" OFFSET $").append(std::to_string(params.size() + 1));
        params.push_back(spido_pg::PgParam::from_text(std::to_string((pg.page - 1) * pg.size)));
{% endif %}

        auto pgres = db.query_cached(
            sql,
            std::span<const spido_pg::PgParam>(params),
            std::chrono::seconds({{ r.cache_ttl_s }}),
            "{{ r.table }}");
        auto dt_us = std::chrono::duration_cast<std::chrono::microseconds>(
                       std::chrono::steady_clock::now() - t0).count();
        rs.record_read(static_cast<uint64_t>(dt_us));
        if (!pgres.ok()) { send_db_error(res, pgres); return; }
        std::string _body;
{% if r.pagination.mode == 'cursor' %}
        size_t _ncols = pgres.fields.size();
{% if r.pagination.include_total %}
        long long _total = 0;
        if (!pgres.rows.empty() && _ncols > 0) {
            if (auto v = pgres.i8(0, _ncols - 1)) _total = *v;
        }
        if (_ncols > 0) --_ncols;
{% endif %}
        std::string _next_cursor;
        if (!pgres.rows.empty()) {
            size_t _pk_idx = SIZE_MAX;
            for (size_t c = 0; c < _ncols; ++c) {
                if (pgres.fields[c].name == "{{ r.primary_key }}") { _pk_idx = c; break; }
            }
            if (_pk_idx != SIZE_MAX) {
                size_t last_row = pgres.rows.size() - 1;
                if (auto v = pgres.i8(last_row, _pk_idx)) _next_cursor = std::to_string(*v);
                else if (auto v = pgres.text(last_row, _pk_idx))
                    _next_cursor.assign(v->data(), v->size());
            }
        }
        _body.reserve(64 + pgres.rows.size() * 64);
        _body += "{\"data\":";
        _body += result_to_json_string(pgres, _ncols);
        _body += ",\"meta\":{\"next_cursor\":";
        if (_next_cursor.empty() || pgres.rows.size() < (size_t)_page_size) {
            _body += "null";
        } else {
            _body += "\""; _body += _next_cursor; _body += "\"";
        }
        _body += ",\"page_size\":";
        _body += std::to_string(_page_size);
{% if r.pagination.include_total %}
        _body += ",\"total\":";
        _body += std::to_string(_total);
{% endif %}
        _body += "}}";
{% elif r.pagination.include_total %}
        long long _total = 0;
        size_t _ncols = pgres.fields.size();
        if (!pgres.rows.empty() && _ncols > 0) {
            if (auto v = pgres.i8(0, _ncols - 1)) _total = *v;
        }
        if (_ncols > 0) --_ncols;
        _body.reserve(64 + pgres.rows.size() * 64);
        _body += "{\"data\":";
        _body += result_to_json_string(pgres, _ncols);
        _body += ",\"meta\":{\"total\":";
        _body += std::to_string(_total);
        _body += ",\"page\":";
        _body += std::to_string(pg.page);
        _body += ",\"page_size\":";
        _body += std::to_string(pg.size);
        _body += ",\"has_next\":";
        _body += ((long long)pg.page * pg.size < _total) ? "true" : "false";
        _body += "}}";
{% elif r.relations %}
        _body = result_to_json_string(pgres);
{% else %}
        _body = result_to_json(pgres).dump();
