        res.set_status(201).json(spido::Json(std::move(_o)));
{% endif %}
    }{% if r.needs_auth %}, /*require_auth=*/true{% endif %});
{% endif %}

{% if 'PUT' in r.methods %}
    // PUT {{ r.path }}/:id → UPDATE (partial; only fields present in body)
    srv.put("{{ r.path }}/:id", [&db](spido::Request& req, spido::Response& res) {
        auto t0 = std::chrono::steady_clock::now();
        auto& rs = db.endpoints().state(kEp_{{ r.table }});
        {{ role_check(r.perms_update, r.perms_header) }}
        {{ bypass_own(r.perms_update, r.perms_header) }}
        auto id = req.param("id");
        if (id.empty()) { res.set_status(400).text("missing id"); return; }
{% if r.ownership %}
        std::string owner_id;
        if (!_bypass_own) {
            std::string _h = {{ user_id_expr(r.ownership) }};
            if (_h.empty()) { res.set_status(401).text("auth required"); return; }
            owner_id.assign(_h);
        }
{% endif %}
        auto body = spido_pg::JsonBody::parse(req.body);
        if (!body) { res.set_status(400).text("invalid json"); return; }
{% if r.has_validations %}
        if (send_validation_errors(res, validate_{{ r.table }}(*body, /*is_create=*/false))) return;
{% endif %}
        auto plan = build_update("{{ r.table }}", "{{ r.primary_key }}",
                                 cols_{{ r.table }}, *body, id);
        if (plan.params.size() == 1) {
            res.set_status(400).text("empty update");
            return;
        }
{% if r.ownership %}
        if (!_bypass_own) {
            plan.sql.append(" AND {{ r.ownership_sql_col }} = $");
            plan.sql.append(std::to_string(plan.params.size() + 1));
            plan.params.push_back(spido_pg::PgParam::from_text(owner_id));
            plan.types.push_back(spido_pg::Oid::Unknown);
        }
{% endif %}
{% if r.soft_delete %}
        plan.sql.append(" AND {{ r.soft_delete_sql_col }} IS NULL");
{% endif %}
{% if r.hook_before_update %}
        {
            std::string _user;
{% if r.ownership %}
            _user.assign(owner_id);
{% endif %}
            std::vector<spido_pg::PgParam> _hp = {
                spido_pg::PgParam::text(id), spido_pg::PgParam::text(_user)
            };
            std::vector<spido_pg::Oid> _ht(2, spido_pg::Oid::Unknown);
            auto _hr = db.pool().exec_prepared("hook_bu_{{ r.table }}",
                R"({{ r.hook_before_update }})",
                std::span<const spido_pg::Oid>(_ht),
                std::span<const spido_pg::PgParam>(_hp));
            if (!_hr.ok()) { send_db_error(res, _hr); return; }
        }
{% endif %}
        auto pgr = db.pool().exec_prepared(
            "upd_{{ r.table }}_" + std::to_string(plan.params.size()),
            plan.sql,
            std::span<const spido_pg::Oid>(plan.types),
            std::span<const spido_pg::PgParam>(plan.params));
        db.cache().invalidate_table("{{ r.table }}");
        auto dt_us = std::chrono::duration_cast<std::chrono::microseconds>(
                       std::chrono::steady_clock::now() - t0).count();
        rs.record_write(static_cast<uint64_t>(dt_us));
        if (!pgr.ok()) { send_db_error(res, pgr); return; }
        if (pgr.tag.size() > 7 && pgr.tag[7] == '0') {
            res.set_status(404).text("not found");
            return;
        }
{% if r.hook_after_update %}
        {
            std::string _user;
{% if r.ownership %}
            _user.assign(owner_id);
{% endif %}
            std::vector<spido_pg::PgParam> _hp = {
                spido_pg::PgParam::text(id), spido_pg::PgParam::text(_user)
            };
            std::vector<spido_pg::Oid> _ht(2, spido_pg::Oid::Unknown);
            auto _hr = db.pool().exec_prepared("hook_au_{{ r.table }}",
                R"({{ r.hook_after_update }})",
                std::span<const spido_pg::Oid>(_ht),
                std::span<const spido_pg::PgParam>(_hp));
            if (!_hr.ok()) {
                std::fprintf(stderr, "after_update hook failed for {{ r.table }}: %s\n",
                             _hr.error_message.c_str());
            }
        }
{% endif %}
        res.json(status_ok());
    }{% if r.needs_auth %}, /*require_auth=*/true{% endif %});
{% endif %}

{% if 'DELETE' in r.methods %}
    // DELETE {{ r.path }}/:id (soft={{ 'yes' if r.soft_delete else 'no' }})
    srv.del("{{ r.path }}/:id", [&db](spido::Request& req, spido::Response& res) {
        auto t0 = std::chrono::steady_clock::now();
        auto& rs = db.endpoints().state(kEp_{{ r.table }});
        {{ role_check(r.perms_delete, r.perms_header) }}
        {{ bypass_own(r.perms_delete, r.perms_header) }}
        auto id = req.param("id");
        if (id.empty()) { res.set_status(400).text("missing id"); return; }
{% if r.ownership %}
        std::string owner_id;
        if (!_bypass_own) {
            std::string _h = {{ user_id_expr(r.ownership) }};
            if (_h.empty()) { res.set_status(401).text("auth required"); return; }
            owner_id.assign(_h);
        }
{% endif %}
        std::vector<spido_pg::PgParam> ps = { pk_param(id) };
        std::vector<spido_pg::Oid>     ts = { spido_pg::Oid::Unknown };
{% if r.soft_delete %}
        std::string sql = "UPDATE {{ r.table }} SET {{ r.soft_delete }} = now() WHERE {{ r.table }}.{{ r.primary_key }} = $1 AND {{ r.soft_delete_sql_col }} IS NULL";
{% else %}
        std::string sql = "DELETE FROM {{ r.table }} WHERE {{ r.table }}.{{ r.primary_key }} = $1";
{% endif %}
{% if r.ownership %}
        if (!_bypass_own) {
            sql.append(" AND {{ r.ownership_sql_col }} = $").append(std::to_string(ps.size() + 1));
            ps.push_back(spido_pg::PgParam::from_text(owner_id));
            ts.push_back(spido_pg::Oid::Unknown);
        }
{% endif %}
{% if r.hook_before_delete %}
        {
            std::string _user;
{% if r.ownership %}
            _user.assign(owner_id);
{% endif %}
            std::vector<spido_pg::PgParam> _hp = {
                spido_pg::PgParam::text(id), spido_pg::PgParam::text(_user)
            };
            std::vector<spido_pg::Oid> _ht(2, spido_pg::Oid::Unknown);
            auto _hr = db.pool().exec_prepared("hook_bd_{{ r.table }}",
                R"({{ r.hook_before_delete }})",
                std::span<const spido_pg::Oid>(_ht),
                std::span<const spido_pg::PgParam>(_hp));
            if (!_hr.ok()) { send_db_error(res, _hr); return; }
        }
{% endif %}
        auto pgr = db.pool().exec_prepared(
            "del_{{ r.table }}",
            sql,
            std::span<const spido_pg::Oid>(ts),
            std::span<const spido_pg::PgParam>(ps));
        db.cache().invalidate_table("{{ r.table }}");
        auto dt_us = std::chrono::duration_cast<std::chrono::microseconds>(
                       std::chrono::steady_clock::now() - t0).count();
        rs.record_write(static_cast<uint64_t>(dt_us));
        if (!pgr.ok()) { send_db_error(res, pgr); return; }
        if (pgr.tag.size() > 7 && pgr.tag[7] == '0') {
            res.set_status(404).text("not found");
            return;
        }
{% if r.hook_after_delete %}
        {
            std::string _user;
{% if r.ownership %}
            _user.assign(owner_id);
{% endif %}
            std::vector<spido_pg::PgParam> _hp = {
                spido_pg::PgParam::text(id), spido_pg::PgParam::text(_user)
            };
            std::vector<spido_pg::Oid> _ht(2, spido_pg::Oid::Unknown);
            auto _hr = db.pool().exec_prepared("hook_ad_{{ r.table }}",
                R"({{ r.hook_after_delete }})",
                std::span<const spido_pg::Oid>(_ht),
                std::span<const spido_pg::PgParam>(_hp));
            if (!_hr.ok()) {
                std::fprintf(stderr, "after_delete hook failed for {{ r.table }}: %s\n",
                             _hr.error_message.c_str());
            }
        }
{% endif %}
        res.set_status(204);
    }{% if r.needs_auth %}, /*require_auth=*/true{% endif %});
{% endif %}
}

