// Resources:
{% for r in resources %}
//   {{ r.path }} [{{ r.methods | join(', ') }}] table={{ r.table }} pk={{ r.primary_key }}{% if r.batch_write %} batch_write{% endif %}{% if r.auth %} auth{% endif %}
{% endfor %}

#include "service_helpers.h"
#include "service_setup.h"
{% if auth.refresh.enabled %}
#include "auth_endpoints.h"
{% endif %}
{% if cfg.files.enabled %}
#include "files_endpoints.h"
{% endif %}
{% if cfg.push.enabled %}
#include "push_endpoints.h"
{% endif %}

{% for r in resources %}
#include "handlers/{{ r.table }}.h"
{% endfor %}

#include <spido/server.h>
#include <spido_pg/db.h>

#include <cstdio>

int main() {
    spido_pg::Db db(svc::build_db_cfg());
    svc::register_endpoint_policies(db.endpoints());

    spido::ServerConfig scfg;
    scfg.port = {{ service.port }};
{% if auth.type == 'jwt' %}
    // JWT bearer auth — spido's built-in verifier runs before our handlers
    // on routes marked require_auth=true. Per-request cache keyed by
    // SHA-256(token) absorbs the verify cost after the first hit.
    scfg.jwt.enabled         = true;
    scfg.jwt.algorithm       = "{{ auth.algo }}";
    scfg.jwt.secret          = "{{ auth.secret }}";
    scfg.jwt.leeway_seconds  = {{ auth.leeway_s }};
{% if auth.issuer %}
    scfg.jwt.issuer          = "{{ auth.issuer }}";
{% endif %}
{% if auth.audience %}
    scfg.jwt.audience        = "{{ auth.audience }}";
{% endif %}
{% endif %}
    spido::Server srv(scfg);

{% for r in resources %}
    svc::handlers::register_{{ r.table }}_routes(srv, db);
{% endfor %}
{% if auth.refresh.enabled %}
    svc::auth::register_auth_routes(srv, db);
{% endif %}
{% if cfg.files.enabled %}
    svc::files::register_files_routes(srv, db);
{% endif %}
{% if cfg.push.enabled %}
    svc::push::register_push_routes(srv, db);
{% endif %}

    svc::register_debug_endpoints(srv, db);

{% for p in proxies %}
    // proxy {{ p.path }} → {{ p.socket }} (timeout: {{ p.timeout_ms }}ms)
    // NOTE: libspido's public Server header doesn't expose a built-in proxy
    // primitive. If you need this route, wire a forwarder against the
    // Unix-socket business backend here.
    srv.get("{{ p.path }}", [](spido::Request&, spido::Response& res) {
        res.set_status(502).text("proxy not yet wired");
    }{% if p.auth %}, /*require_auth=*/true{% endif %});
{% endfor %}

    std::fprintf(stderr, "{{ service.name }}: listening on :{{ service.port }}\n");
    srv.listen();
    return 0;
}
