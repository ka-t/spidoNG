# generated by spido-pg generator. do not edit by hand.

cmake_minimum_required(VERSION 3.16)
project({{ service.name }} CXX)

set(CMAKE_CXX_STANDARD 20)
set(CMAKE_CXX_STANDARD_REQUIRED ON)
set(CMAKE_CXX_EXTENSIONS OFF)

if(NOT CMAKE_BUILD_TYPE)
  set(CMAKE_BUILD_TYPE Release)
endif()

add_compile_options(-Wall -Wextra -O3)

# Caller supplies -DSPIDO_DIR= (spido source tree, must contain include/spido)
# and -DSPIDO_PG_DIR= (spido-pg source tree). Library lookup is permissive —
# we search every conventional build layout so the same generated CMakeLists
# works whether the libraries were:
#   • built standalone:     <spido>/build/libspido.a
#   • built via SpidoNG umbrella: <repo>/build/spido/libspido.a
#   • installed system-wide: /usr/local/lib/libspido.a
# Pass -DSPIDO_LIB_DIR= or -DSPIDO_PG_LIB_DIR= to force a specific path.
set(SPIDO_DIR    "{{ spido_dir or '../../spido' }}"        CACHE PATH "")
set(SPIDO_PG_DIR "{{ spido_pg_dir or '../../spido-pg' }}"  CACHE PATH "")

# Common build-output layouts. ../build/spido and ../build/spido-pg cover
# the umbrella case (SpidoNG/build/{spido,spido-pg}/lib<x>.a).
set(SPIDO_LIB_DIR
    "${SPIDO_DIR}"
    "${SPIDO_DIR}/build"
    "${SPIDO_DIR}/../build/spido"
    "${SPIDO_PG_DIR}/../build/spido"
    "${SPIDO_PG_DIR}"
    CACHE STRING "Override paths searched for libspido.a")
set(SPIDO_PG_LIB_DIR
    "${SPIDO_PG_DIR}/build"
    "${SPIDO_PG_DIR}"
    "${SPIDO_PG_DIR}/../build/spido-pg"
    "${SPIDO_DIR}/../build/spido-pg"
    CACHE STRING "Override paths searched for libspido_pg.a")

find_library(SPIDO_LIB    NAMES spido    PATHS ${SPIDO_LIB_DIR}    NO_DEFAULT_PATH REQUIRED)
find_library(SPIDO_PG_LIB NAMES spido_pg PATHS ${SPIDO_PG_LIB_DIR} NO_DEFAULT_PATH REQUIRED)

find_package(PkgConfig REQUIRED)
# Auto-detect a sibling liburing install (libspido needs ≥ 2.5; system 2.0
# would silently link and explode on undefined symbols). Same logic as the
# spido/spido-pg roots — keep it in sync if you change one.
if(NOT DEFINED ENV{SPIDO_LIBURING_PREFIX})
    foreach(_cand
        "${SPIDO_DIR}/../liburing-prefix"
        "${SPIDO_PG_DIR}/../liburing-prefix"
        "$ENV{HOME}/http/liburing-prefix"
        "/opt/liburing"
        "/usr/local")
        if(EXISTS "${_cand}/lib/pkgconfig/liburing.pc")
            set(ENV{SPIDO_LIBURING_PREFIX} "${_cand}")
            message(STATUS "{{ service.name }}: auto-detected liburing at ${_cand}")
            break()
        endif()
    endforeach()
endif()
if(DEFINED ENV{SPIDO_LIBURING_PREFIX})
    set(ENV{PKG_CONFIG_PATH}
        "$ENV{SPIDO_LIBURING_PREFIX}/lib/pkgconfig:$ENV{PKG_CONFIG_PATH}")
endif()
# IMPORTED_TARGET binds the -L to the target so the linker can't fall back
# to system liburing 2.0.
pkg_check_modules(URING REQUIRED IMPORTED_TARGET liburing)
message(STATUS "{{ service.name }}: liburing ${URING_VERSION} from ${URING_LIBRARY_DIRS}")
find_package(OpenSSL REQUIRED)
find_package(Threads REQUIRED)

add_executable({{ service.name }}
  main.cpp
  service_setup.cpp
{% if cfg.auth.refresh.enabled %}
  auth_endpoints.cpp
{% endif %}
{% if cfg.files.enabled %}
  files_endpoints.cpp
{% endif %}
{% if cfg.push.enabled %}
  push_endpoints.cpp
{% endif %}
{% for r in resources %}
  handlers/{{ r.table }}.cpp
{% endfor %}
)
target_include_directories({{ service.name }} PRIVATE
  ${SPIDO_DIR}/include
  ${SPIDO_PG_DIR}/include
  ${CMAKE_CURRENT_SOURCE_DIR})
target_link_libraries({{ service.name }} PRIVATE
  ${SPIDO_PG_LIB}
  ${SPIDO_LIB}
  PkgConfig::URING
  OpenSSL::SSL OpenSSL::Crypto
  Threads::Threads)
